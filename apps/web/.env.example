# Base URL of the NestJS API (exposed to the browser via Vite)
VITE_API_URL=http://localhost:3000
VITE_API_PROXY_TARGET=http://localhost:3000
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
VITE_PAYMENT_CURRENCY=usd
VITE_PAYMENT_CURRENCY_SYMBOL=$
VITE_DEMO_ORDER_ID=DEMO-0001

# Site identity (used for SEO meta tags and structured data)
VITE_SITE_URL=https://uevent.app
VITE_SITE_NAME=UEVENT
VITE_SITE_DESCRIPTION=Discover, create, and attend events near you

# Optional: override default sidebar keyboard shortcut (default: b)
# VITE_SIDEBAR_SHORTCUT_KEY=b
