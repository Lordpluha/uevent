{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"root": true,
	"files": {
		"ignoreUnknown": false
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"linter": {
			"enabled": true,
			"rules": {
					"recommended": true
			}
	},
	"formatter": {
		"enabled": true,
			"lineWidth": 120,
			"indentStyle": "space",
			"indentWidth": 2
	}
}